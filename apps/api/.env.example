NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://dorify_user:dorify_dev_pass@localhost:5432/dorify_v2_db
REDIS_URL=redis://localhost:6379/5

JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=24h

BOT_TOKEN=your-telegram-bot-token

ALLOWED_ORIGINS=*

# Multicard (optional, per-pharmacy in DB)
MULTICARD_CALLBACK_URL=https://api.dorify.uz/api/v1/payments/callback

# Encryption key for Multicard secrets (AES-256)
ENCRYPTION_KEY=change-this-to-a-random-string-at-least-32-chars

# Telegram initData TTL (seconds)
INIT_DATA_TTL_SECONDS=86400
